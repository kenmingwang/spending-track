{
  "manifest_version": 3,
  "name": "Spending Track",
  "version": "1.0",
  "description": "Track spending and calculate credit card benefits",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "alarms",
    "notifications"
  ],
  "background": {
    "service_worker": "src/background.ts"
  },
  "action": {
    "default_popup": "popup/index.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.uob.com.sg/*", "*://*.uobgroup.com/*"],
      "js": ["src/content-scripts/uobNetworkHook.ts"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["*://internet-banking.dbs.com.sg/*", "*://*/*"],
      "js": ["src/content-scripts/extractor.ts"]
    }
  ]
}
